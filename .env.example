# Deploy scripts: copy to .env and set your values (never commit .env)
#
# Shared defaults for deploy.sh and deploy_simulator.sh:
DEPLOY_HOST=user@your-homeassistant-host
DEPLOY_PATH=/config
#
# Optional overrides per script:
# SOLAR_MIND_HOST=user@host
# SOLAR_MIND_PATH=/config
# SOLAX_SIMULATOR_HOST=user@host
# SOLAX_SIMULATOR_PATH=/config
